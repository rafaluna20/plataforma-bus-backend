# ─── Variables de entorno — Transporte Core Backend ───────────────────────────
# Copiar este archivo a .env y completar los valores
# NUNCA commitear el archivo .env al repositorio
#
# ─── Dev / Staging / Producción ────────────────────────────────────────────────
# NODE_ENV se deja SIEMPRE en "development" o "production" — nunca "staging".
# Express y varias librerías tienen comportamiento propio ligado al string
# exacto "production" (páginas de error, cacheo, etc.); un tercer valor las
# confundiría. Por eso: NODE_ENV=production en STAGING y en PRODUCCIÓN por
# igual — es lo que activa todas las protecciones (secretos obligatorios,
# cookies secure, sin auto-sync de esquema, CORS estricto).
#
# Para distinguir staging de producción (en logs y Sentry) usa APP_ENV, que es
# puramente informativo y no activa/desactiva nada:
#   Local:      NODE_ENV=development  (APP_ENV no hace falta)
#   Staging:    NODE_ENV=production   APP_ENV=staging
#   Producción: NODE_ENV=production   APP_ENV=production
#
# Lo que SÍ debe ser distinto entre staging y producción es la infraestructura
# real detrás de cada variable: DB_HOST/DB_NAME (bases de datos separadas —
# nunca compartir la misma BD entre entornos), REDIS_HOST, CORS_ORIGIN (los
# dominios del frontend de cada entorno), y JWT_SECRET/JWT_REFRESH_SECRET
# (secretos distintos por entorno, para que una fuga en staging no comprometa
# las sesiones de producción).

# ─── Servidor ─────────────────────────────────────────────────────────────────
NODE_ENV=development
# APP_ENV=staging
PORT=3001

# ─── Base de datos PostgreSQL ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=transporte_core
DB_USER=transporte_user
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
# TLS es opt-in: poner DB_SSL=true solo si tu Postgres lo soporta (la mayoria
# de proveedores gestionados como Render/Railway/Supabase/RDS lo exigen). Un
# Postgres autoalojado sin TLS (ej. detras de Coolify/Docker) debe dejarlo en
# false, incluso en produccion, o la conexion falla.
DB_SSL=false

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# ─── JWT (OBLIGATORIO cambiar en producción) ──────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_SECRET_ALEATORIO_DE_64_BYTES
JWT_REFRESH_SECRET=CAMBIAR_POR_OTRO_SECRET_ALEATORIO_DE_64_BYTES
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Frontend (CORS) ──────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Dominios permitidos para la API y para el CORS de Socket.io, separados por
# coma. DEBE apuntar al dominio real del frontend de CADA entorno (no dejar el
# default de localhost fuera de development).
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Limite por empresa (no por IP) en los endpoints de gestion B2B, por ventana
# de 15 minutos. Ajustar segun el volumen real de uso del panel administrativo.
COMPANY_RATE_LIMIT_MAX=500

# ─── Monitoreo (opcional) ─────────────────────────────────────────────────────
# Obtener DSN en: https://sentry.io
SENTRY_DSN=

# ─── Pagos (opcional) ─────────────────────────────────────────────────────────
PAYMENT_GATEWAY_API_KEY=
PAYMENT_GATEWAY_SECRET=
